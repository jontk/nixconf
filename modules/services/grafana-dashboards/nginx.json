{
  "dashboard": {
    "id": null,
    "title": "Nginx Monitoring",
    "tags": ["nginx", "web server"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Nginx Status",
        "type": "stat",
        "targets": [
          {
            "expr": "nginx_up",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"options": {"0": {"text": "DOWN", "color": "red"}}, "type": "value"},
              {"options": {"1": {"text": "UP", "color": "green"}}, "type": "value"}
            ]
          }
        },
        "gridPos": {"h": 6, "w": 6, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Active Connections",
        "type": "stat",
        "targets": [
          {
            "expr": "nginx_connections_active",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        },
        "gridPos": {"h": 6, "w": 6, "x": 6, "y": 0}
      },
      {
        "id": 3,
        "title": "Requests per Second",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(nginx_http_requests_total[5m])",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "decimals": 2
          }
        },
        "gridPos": {"h": 6, "w": 6, "x": 12, "y": 0}
      },
      {
        "id": 4,
        "title": "Response Time",
        "type": "stat",
        "targets": [
          {
            "expr": "nginx_http_request_duration_seconds{quantile=\"0.5\"}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "decimals": 3
          }
        },
        "gridPos": {"h": 6, "w": 6, "x": 18, "y": 0}
      },
      {
        "id": 5,
        "title": "Request Rate",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(nginx_http_requests_total[5m])",
            "refId": "A",
            "legendFormat": "Requests/sec"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6}
      },
      {
        "id": 6,
        "title": "Active Connections Over Time",
        "type": "timeseries",
        "targets": [
          {
            "expr": "nginx_connections_active",
            "refId": "A",
            "legendFormat": "Active"
          },
          {
            "expr": "nginx_connections_reading",
            "refId": "B",
            "legendFormat": "Reading"
          },
          {
            "expr": "nginx_connections_writing",
            "refId": "C",
            "legendFormat": "Writing"
          },
          {
            "expr": "nginx_connections_waiting",
            "refId": "D",
            "legendFormat": "Waiting"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6}
      },
      {
        "id": 7,
        "title": "HTTP Status Codes",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(nginx_http_requests_total{status=~\"2..\"}[5m])",
            "refId": "A",
            "legendFormat": "2xx Success"
          },
          {
            "expr": "rate(nginx_http_requests_total{status=~\"3..\"}[5m])",
            "refId": "B",
            "legendFormat": "3xx Redirect"
          },
          {
            "expr": "rate(nginx_http_requests_total{status=~\"4..\"}[5m])",
            "refId": "C",
            "legendFormat": "4xx Client Error"
          },
          {
            "expr": "rate(nginx_http_requests_total{status=~\"5..\"}[5m])",
            "refId": "D",
            "legendFormat": "5xx Server Error"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14}
      },
      {
        "id": 8,
        "title": "Response Time Percentiles",
        "type": "timeseries",
        "targets": [
          {
            "expr": "nginx_http_request_duration_seconds{quantile=\"0.5\"}",
            "refId": "A",
            "legendFormat": "50th percentile"
          },
          {
            "expr": "nginx_http_request_duration_seconds{quantile=\"0.95\"}",
            "refId": "B",
            "legendFormat": "95th percentile"
          },
          {
            "expr": "nginx_http_request_duration_seconds{quantile=\"0.99\"}",
            "refId": "C",
            "legendFormat": "99th percentile"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14}
      },
      {
        "id": 9,
        "title": "Request Size",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(nginx_http_request_size_bytes_sum[5m]) / rate(nginx_http_request_size_bytes_count[5m])",
            "refId": "A",
            "legendFormat": "Average Request Size"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bytes"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 22}
      },
      {
        "id": 10,
        "title": "Response Size",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(nginx_http_response_size_bytes_sum[5m]) / rate(nginx_http_response_size_bytes_count[5m])",
            "refId": "A",
            "legendFormat": "Average Response Size"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bytes"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 22}
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "refresh": "30s"
  }
}
#!/usr/bin/env bash
# Git pre-commit hook
# This file is managed by Home Manager

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Check for debugging
if [ -n "$DEBUG" ]; then
  set -x
fi

echo "Running pre-commit checks..."

# Check for merge conflicts
if git diff --cached --name-only | xargs grep -E '^(<<<<<<<|=======|>>>>>>>)' 2>/dev/null; then
  echo -e "${RED}Error: Merge conflict markers found${NC}"
  git diff --cached --name-only | xargs grep -n -E '^(<<<<<<<|=======|>>>>>>>)' || true
  exit 1
fi

# Check for large files (>10MB)
while read -r file; do
  if [ -f "$file" ]; then
    size=$(ls -l "$file" | awk '{print $5}')
    if [ "$size" -gt 10485760 ]; then
      echo -e "${RED}Error: Large file detected: $file ($(numfmt --to=iec-i --suffix=B "$size"))${NC}"
      echo "Consider using Git LFS for large files"
      exit 1
    fi
  fi
done < <(git diff --cached --name-only)

# Check for sensitive data patterns
patterns=(
  "PRIVATE KEY"
  "private_key"
  "aws_access_key_id"
  "aws_secret_access_key"
  "api_key"
  "apikey"
  "access_token"
  "auth_token"
  "credentials"
  "password"
  "passwd"
)

for pattern in "${patterns[@]}"; do
  if git diff --cached --name-only | xargs grep -i "$pattern" 2>/dev/null; then
    echo -e "${YELLOW}Warning: Possible sensitive data found (pattern: $pattern)${NC}"
    echo "Please review and ensure no secrets are being committed"
    read -p "Continue anyway? (y/N) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
      exit 1
    fi
  fi
done

# Check for trailing whitespace
if git diff --cached --check; then
  :
else
  echo -e "${RED}Error: Trailing whitespace detected${NC}"
  echo "Run 'git diff --cached --check' to see details"
  exit 1
fi

# Language-specific checks
# Python
if git diff --cached --name-only | grep -E '\.py$' >/dev/null; then
  if command -v black >/dev/null 2>&1; then
    echo "Checking Python formatting..."
    git diff --cached --name-only --diff-filter=ACM | grep -E '\.py$' | xargs -r black --check --quiet || {
      echo -e "${YELLOW}Warning: Python files not formatted with black${NC}"
      echo "Run 'black .' to format"
    }
  fi
fi

# JavaScript/TypeScript
if git diff --cached --name-only | grep -E '\.(js|jsx|ts|tsx)$' >/dev/null; then
  if command -v prettier >/dev/null 2>&1; then
    echo "Checking JavaScript/TypeScript formatting..."
    git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|jsx|ts|tsx)$' | xargs -r prettier --check || {
      echo -e "${YELLOW}Warning: JS/TS files not formatted with prettier${NC}"
      echo "Run 'prettier --write .' to format"
    }
  fi
fi

# Nix
if git diff --cached --name-only | grep -E '\.nix$' >/dev/null; then
  if command -v nixpkgs-fmt >/dev/null 2>&1; then
    echo "Checking Nix formatting..."
    git diff --cached --name-only --diff-filter=ACM | grep -E '\.nix$' | xargs -r nixpkgs-fmt --check || {
      echo -e "${YELLOW}Warning: Nix files not formatted${NC}"
      echo "Run 'nixpkgs-fmt .' to format"
    }
  fi
fi

echo -e "${GREEN}Pre-commit checks passed${NC}"